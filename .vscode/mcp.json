import json
import subprocess
import sys
from typing import Dict, Any, Optional
import asyncio
import aiohttp
from pathlib import Path

class PerplexityMCPClient:
    """A client for interacting with Perplexity MCP server"""
    
    def __init__(self):
        """Initialize the Perplexity MCP client"""
        # Based on your .mcp.json.tmp configuration
        self.command = "C:\\Program Files\\nodejs\\node.exe"
        self.args = ["C:\\Users\\RickCain\\.perplexity-mcp\\start.mjs"]
        self.process = None
        
    async def start_server(self):
        """Start the Perplexity MCP server process"""
        try:
            # Start the MCP server as a subprocess
            self.process = await asyncio.create_subprocess_exec(
                self.command,
                *self.args,
                stdin=asyncio.subprocess.PIPE,
                stdout=asyncio.subprocess.PIPE,
                stderr=asyncio.subprocess.PIPE
            )
            print("Perplexity MCP server started successfully")
        except Exception as e:
            print(f"Failed to start Perplexity MCP server: {e}")
            
    async def stop_server(self):
        """Stop the Perplexity MCP server process"""
        if self.process and self.process.returncode is None:
            self.process.terminate()
            await self.process.wait()
            
    async def _send_request(self, method: str, params: Dict) -> Dict[str, Any]:
        """Send a request to the MCP server"""
        if not self.process:
            await self.start_server()
            
        request = {
            "jsonrpc": "2.0",
            "method": method,
            "params": params,
            "id": 1
        }
        
        try:
            # Send request to MCP server
            self.process.stdin.write(json.dumps(request).encode() + b'\n')
            await self.process.stdin.drain()
            
            # Read response
            line = await self.process.stdout.readline()
            response = json.loads(line.decode())
            return response
        except Exception as e:
            return {"error": str(e)}
    
    async def perplexity_search(self, query: str, language: str = "en-US") -> Dict[str, Any]:
        """
        Perform a fast web search with source citations.
        
        Args:
            query (str): The search query
            language (str): Language code (default: en-US)
            
        Returns:
            Dict containing search results
        """
        params = {
            "query": query,
            "language": language
        }
        return await self._send_request("perplexity_search", params)
    
    async def perplexity_reason(self, query: str) -> Dict[str, Any]:
        """
        Perform step-by-step reasoning with web context.
        Requires Pro account.
        
        Args:
            query (str): The reasoning query
            
        Returns:
            Dict containing reasoning results
        """
        params = {
            "query": query
        }
        return await self._send_request("perplexity_reason", params)
    
    async def perplexity_research(self, query: str) -> Dict[str, Any]:
        """
        Generate deep multi-section research reports.
        Requires Pro account.
        
        Args:
            query (str): The research query
            
        Returns:
            Dict containing research report
        """
        params = {
            "query": query
        }
        return await self._send_request("perplexity_research", params)
    
    async def perplexity_ask(self, query: str, model: Optional[str] = None, 
                      mode: Optional[str] = None) -> Dict[str, Any]:
        """
        Flexible queries with explicit model/mode control.
        
        Args:
            query (str): The query
            model (str, optional): Specific model to use
            mode (str, optional): Mode of operation
            
        Returns:
            Dict containing response
        """
        params = {
            "query": query
        }
        if model:
            params["model"] = model
        if mode:
            params["mode"] = mode
            
        return await self._send_request("perplexity_ask", params)

# Example usage functions that Copilot can help with:
async def search_market_info(topic: str) -> Dict[str, Any]:
    """
    Search for market information using Perplexity.
    
    Args:
        topic (str): Market topic to search for
        
    Returns:
        Dict containing search results
    """
    client = PerplexityMCPClient()
    await client.start_server()
    try:
        result = await client.perplexity_search(f"Kalshi trading {topic}")
        return result
    finally:
        await client.stop_server()

